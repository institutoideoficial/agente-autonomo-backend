# Copie para .env e preencha. NAO commitar .env (ja esta no .gitignore).

# Dominio apontado para o IP da VPS (DNS A record). Se nao tiver dominio, use o IP.
DOMAIN_CRM=crm.seudominio.com

# Subdominio opcional pro painel QR do Bravos. Deixe vazio se nao usar.
DOMAIN_BRAVOS=

# Email pro Let's Encrypt (certificados SSL automaticos)
ACME_EMAIL=vanessa@seudominio.com

# Token compartilhado entre CRM e Bravos. Gere um novo:
#   openssl rand -hex 32
API_TOKEN=sp_GERE_UM_NOVO_AQUI_com_openssl_rand_hex_32

# Opcional: chave Anthropic. Sem ela, /api/bot retorna 500 (conforme intencional).
ANTHROPIC_API_KEY=
