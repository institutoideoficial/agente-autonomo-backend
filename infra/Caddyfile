# Caddyfile - HTTPS automatico via Let's Encrypt
# As variaveis {$DOMAIN_CRM}, {$DOMAIN_BRAVOS}, {$ACME_EMAIL} vem do docker-compose.

{
    email {$ACME_EMAIL}
}

# CRM (frontend + API + SSE)
{$DOMAIN_CRM} {
    encode gzip

    # OAuth do agente Sofia (separado do CRM): /agent-oauth/google/* -> agent:8000/oauth/google/*
    handle_path /agent-oauth/* {
        rewrite * /oauth{uri}
        reverse_proxy agent:8000
    }

    # SSE precisa manter conexao aberta; desabilita buffer do proxy
    @sse path /events
    handle @sse {
        reverse_proxy crm:3000 {
            flush_interval -1
            transport http {
                read_timeout 24h
            }
        }
    }

    handle {
        reverse_proxy crm:3000
    }

    log {
        output stdout
        format console
    }
}

