# Caddyfile - HTTPS automatico via Let's Encrypt
# Variaveis: {$DOMAIN_CRM}, {$DOMAIN_SOFIA}, {$DOMAIN_BRAVOS}, {$ACME_EMAIL} vem do docker-compose.
#
# Caddy compartilhado entre stacks: CRM Imperador e Sofia Agent.
# - {$DOMAIN_CRM} -> crm:3000 (Imperador)
# - {$DOMAIN_SOFIA} -> sofia-agent:8000 (Sofia, stack separado em /opt/sofia-agent)
#
# Pra Caddy alcancar containers da Sofia (em outro stack), ele entra na
# rede docker `imperador_edge` (external) — ver docker-compose deste arquivo
# e o do /opt/sofia-agent/infra/.

{
    email {$ACME_EMAIL}
}

# CRM Imperador
{$DOMAIN_CRM} {
    encode gzip

    # SSE precisa manter conexao aberta; desabilita buffer do proxy
    @sse path /events
    handle @sse {
        reverse_proxy crm:3000 {
            flush_interval -1
            transport http {
                read_timeout 24h
            }
        }
    }

    handle {
        reverse_proxy crm:3000
    }

    log {
        output stdout
        format console
    }
}

# Sofia (agente autonomo) — stack separado, mesmo Caddy pra HTTPS
{$DOMAIN_SOFIA} {
    encode gzip
    reverse_proxy sofia-agent:8000

    log {
        output stdout
        format console
    }
}

