# Modelo Anthropic (raciocinio principal)
ANTHROPIC_API_KEY=sk-ant-...
AGENT_MODEL=claude-opus-4-7
AGENT_MODEL_FAST=claude-haiku-4-5

# Whitelist de numeros que o agente conversa (CSV, so digitos)
# Modo treino: so esses respondem. Modo prod: todos.
AGENT_MODE=treino
AGENT_WHITELIST=5512982933600

# Comunicacao com o CRM Node (mesma rede docker)
CRM_URL=http://crm:3000
# Token compartilhado pra o CRM autenticar chamadas vindas do agent (futuro)
AGENT_TO_CRM_TOKEN=

# SQLite cerebro
AGENT_DB_PATH=/app/data/agent.db

# Auditoria
AGENT_LOG_LEVEL=INFO
